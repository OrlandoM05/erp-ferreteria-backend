# App
APP_NAME=ERP Ferreteria
ENV=development
DEBUG=1

# Security
SECRET_KEY=super-secret-key-cambiar
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Database
POSTGRES_USER=erp_user
POSTGRES_PASSWORD=erp_password
POSTGRES_DB=erp_ferreteria
